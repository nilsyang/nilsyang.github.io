<section id="publications" style="border-top: 1px solid var(--color-tertiary);">
  <div class="section-inner">
    <p class="section-label">Publications</p>
    <h2 style="font-size: clamp(27px, 3vw, 48px); margin-bottom: 1rem;">Selected Publications</h2>
    <p style="color: var(--color-secondary); margin: 0 0 2.5rem;">
      22 peer-reviewed articles including 13 as first author.
      <a
        href="https://scholar.google.com/citations?user=sHvN8soAAAAJ&hl=en"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--color-primary);"
      >
        Full list on Google Scholar →
      </a>
    </p>

    <div style="display: flex; flex-direction: column; gap: 0;">
      {publications.map(({ authors, year, title, journal, volume, doi, highlight, note }, i) => (
        <div style={`
          padding: 1.25rem 0;
          border-top: 1px solid var(--color-tertiary);
          ${i === publications.length - 1 ? 'border-bottom: 1px solid var(--color-tertiary);' : ''}
          display: grid;
          grid-template-columns: 3rem 1fr;
          gap: 1rem;
          align-items: start;
        `}>
          <span style="font-size: 13px; color: var(--color-secondary); font-weight: 500; padding-top: 0.15em; font-family: ui-monospace, monospace;">
            {year}
          </span>
          <div>
            <p style="margin: 0 0 0.3rem; font-weight: 600; font-size: clamp(15px, 1.3vw, 17px); line-height: 1.3; letter-spacing: -0.01em;">
              {title}
            </p>
            <p style="margin: 0 0 0.3rem; font-size: 14px; color: var(--color-secondary);">{authors}</p>
            <p style="margin: 0; font-size: 14px;">
              <em style="font-style: normal; color: var(--color-primary); font-weight: 500;">{journal}</em>
              {volume && <span style="color: var(--color-secondary);">, {volume}</span>}
            </p>
            {note && (
              <p style="margin: 0.4rem 0 0; font-size: 13px; color: #b45309; font-weight: 600;">{note}</p>
            )}
            {doi && (
              <a
                href={doi}
                target="_blank"
                rel="noopener noreferrer"
                style="display: inline-block; margin-top: 0.4rem; font-size: 12px; font-family: ui-monospace, monospace; color: var(--color-secondary); text-decoration: none;"
              >
                {doi.replace('https://', '')}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <p style="font-size: 13px; color: var(--color-secondary); margin-top: 1.25rem;">
      * denotes equal contribution
    </p>
  </div>
</section>
